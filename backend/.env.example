# RPC endpoint of the blockchain network (Hardhat local node, or Sepolia testnet, etc.)
RPC_URL=http://127.0.0.1:8545

# Private key of the backend's "relayer" wallet (used only for read calls /
# optional gas-sponsored transactions). NEVER commit a real private key.
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Deployed contract address (copy from deployments/BlockCertify.json after deploy)
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa

# Port for the Express server
PORT=4000

# Allowed origin for CORS (frontend dev server)
CORS_ORIGIN=http://localhost:5173
